package components

// Skeleton loading block. lines is visual row count (1-6).
templ Skeleton(lines int) {
	<div class="ds-skeleton" aria-busy="true" aria-label="Loading">
		for i := 0; i < skeletonLines(lines); i++ {
			<div class="ds-skeleton__line"></div>
		}
	</div>
}

func skeletonLines(n int) int {
	if n < 1 {
		return 3
	}
	if n > 6 {
		return 6
	}
	return n
}
