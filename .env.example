# LOXTU — host-side environment template
# Copy to .env (NEVER commit .env). docker-compose reads this at runtime.
# The Docker image does NOT bake these values in.

# ── Process ──────────────────────────────────────────────
LISTEN_ADDR=0.0.0.0:8880
LOXTU_VERSION=dev

# Required — HS256 JWT signing key (min 32 random bytes recommended)
LOXTU_JWT_SECRET=change-me-to-a-long-random-secret

# ── SurrealDB (internal/config SurrealDBFromEnv) ─────────
# WebSocket endpoint of SurrealDB router
SURREALDB_ENDPOINT=ws://surrealdb:8881/rpc
# Root credentials for pool connections
SURREALDB_USER=root
SURREALDB_PASS=root
# Default control-plane namespace/database
SURREALDB_NS=loxtu
SURREALDB_DB=loxtu
# Max concurrent pooled connections
SURREALDB_POOL_SIZE=10

# ── SMTP (internal/config SMTPFromEnv) ───────────────────
SMTP_HOST=stalwart
SMTP_PORT=465
SMTP_USER=noreply@loxtu.com
SMTP_PASSWORD=
SMTP_FROM=noreply@loxtu.com
SMTP_FROM_NAME=LOXTU
# true = dial SMTP; false = log OTP to stdout (dev)
SMTP_ENABLED=false
# Optional SNI override for TLS 465
SMTP_TLS_SERVERNAME=

# ── WebAuthn (composition root / main envOr) ─────────────
WEBAUTHN_RPID=app.loxtu.com
WEBAUTHN_ORIGIN=https://app.loxtu.com
